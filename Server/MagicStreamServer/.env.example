# MORA Streaming Application - Environment Configuration

# Database Configuration
# Database name for MongoDB
DATABASE_NAME=MORA-stream-Movies

# MongoDB Connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/

# API Configuration
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# JWT Configuration (if applicable)
JWT_SECRET=your_jwt_secret_key_here

# OpenAI Configuration (for AI-based review ranking)
OPENAI_API_KEY=your_openai_api_key_here
BASE_PROMPT_TEMPLATE=Analyze this movie review and classify it as one of these sentiments: {rankings}. Return only the sentiment name. Review:

# Recommended Movies Configuration
# Number of recommended movies to fetch
RECOMMENDED_MOVIE_LIMIT=5

# Server Configuration
PORT=8080
GIN_MODE=debug
